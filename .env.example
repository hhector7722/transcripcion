# Firebase (opcional). Si no se configuran, la app funciona solo con archivos locales.
# Para audios en la nube (móvil): Storage + Firestore, manteniendo solo los 5 más recientes.

# Opción A: JSON de la cuenta de servicio (recomendado en producción)
# Descarga el JSON desde Firebase Console → Project settings → Service accounts → Generate new private key.
FIREBASE_CREDENTIALS_JSON={"type":"service_account",...}

# Opción B: ruta a un archivo .json de la cuenta de servicio
# GOOGLE_APPLICATION_CREDENTIALS=./serviceAccountKey.json

# Nombre del bucket de Storage (ej: mi-proyecto.appspot.com)
FIREBASE_STORAGE_BUCKET=tu-proyecto-id.appspot.com
